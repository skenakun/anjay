# Allow wifi HAL to search the directory and read files created by wcnss service
allow hal_wifi_default vendor_wifi_vendor_data_file:dir search;
allow hal_wifi_default vendor_wifi_vendor_data_file:file r_file_perms;
get_prop(hal_wifi_default, persist_vendor_debug_wifi_prop)

allow hal_wifi_default vendor_tombstone_data_file:dir rw_dir_perms;
allow hal_wifi_default vendor_tombstone_data_file:file create_file_perms;
allow hal_wifi_default self:capability sys_module;
